<script>
  // Filter chip toggle
  function toggleChip(el) {
    el.closest('.filter-row').querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
  }

  // Live feed simulation
  const feedItems = [
    { color: 'var(--accent)', text: '<strong>Replay imported:</strong> <span class="hl">karMa</span> vs Team Void — <span class="hl-green">7 new patterns</span> indexed' },
    { color: 'var(--gold)', text: '<span class="hl-gold">Meta shift:</span> Blink Dagger rush on offlane trending — seen in <span class="hl">34 pro matches</span> this week' },
    { color: 'var(--red)', text: '<strong>Alert:</strong> <span class="hl-red">Roshan response time critical</span> — sub 35-sec response required to secure Aegis' },
    { color: 'var(--accent3)', text: '<span class="hl-green">Improvement detected:</span> <strong>revenant_x</strong> vision score ↑ <span class="hl">+18%</span> this week' },
    { color: 'var(--accent2)', text: '<strong>Matchup study available:</strong> <span class="hl">vs Storm Gaming</span> — 12 historical matches analyzed' },
  ];

  let feedIndex = 0;
  setInterval(() => {
    const feed = document.getElementById('liveFeed');
    const item = feedItems[feedIndex % feedItems.length];
    const el = document.createElement('div');
    el.className = 'feed-item';
    el.innerHTML = `
      <div class="feed-time">LIVE</div>
      <div class="feed-dot" style="background:${item.color}"></div>
      <div class="feed-text">${item.text}</div>
    `;
    feed.insertBefore(el, feed.firstChild);
    if (feed.children.length > 10) feed.removeChild(feed.lastChild);
    feedIndex++;
  }, 6000);

  // Toast notifications
  const toasts = [
    { msg: '<strong>New scrim scheduled:</strong> vs Iron Gate in 2 hours', cls: '' },
    { msg: '<strong>Patch 7.36 analysis</strong> complete — <span class="hl">14 hero changes</span> affect your pool', cls: 'orange' },
    { msg: '<strong>VOD processing done:</strong> Arteezy stream — 12 insights ready', cls: 'green' },
  ];

  function showToast(idx) {
    const stack = document.getElementById('toastStack');
    const t = document.createElement('div');
    t.className = `toast ${toasts[idx].cls}`;
    t.innerHTML = `
      <div>⬡</div>
      <div class="toast-msg">${toasts[idx].msg}</div>
    `;
    stack.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.5s'; setTimeout(() => t.remove(), 500); }, 4000);
  }

  setTimeout(() => showToast(0), 1500);
  setTimeout(() => showToast(1), 5000);
  setTimeout(() => showToast(2), 9000);
</script>

