<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AEGIS — Dota 2 Analytics Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&family=Barlow+Condensed:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #020508;
    --bg2: #040c12;
    --bg3: #071420;
    --panel: #0a1a28;
    --panel2: #0d2035;
    --border: #1a3a52;
    --border2: #0f2a3f;
    --accent: #00c8ff;
    --accent2: #ff6b35;
    --accent3: #7fff5a;
    --gold: #ffd166;
    --red: #ff3b5c;
    --text: #c8dde8;
    --text2: #7aA0b8;
    --text3: #3a607a;
    --glow: 0 0 20px rgba(0,200,255,0.3);
    --glow2: 0 0 20px rgba(255,107,53,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Barlow Condensed', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* SCANLINES OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.07) 2px,
      rgba(0,0,0,0.07) 4px
    );
    pointer-events: none;
    /* lowered so interactive UI (toasts, overlays) can render above the effect */
    z-index: 50;
  }

  /* ——— NAV ——— */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 64px;
    background: rgba(4,12,18,0.95);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--accent), #0066aa);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    box-shadow: var(--glow);
  }

  .logo-text {
    font-family: 'Rajdhani', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 6px;
    color: #fff;
    text-transform: uppercase;
  }

  .logo-sub {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--accent);
    font-family: 'Share Tech Mono', monospace;
    margin-top: -2px;
  }

  nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
  }

  nav a {
    color: var(--text2);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    padding: 8px 16px;
    text-transform: uppercase;
    transition: all 0.2s;
    position: relative;
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 16px; right: 16px;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.2s;
  }

  nav a:hover { color: var(--accent); }
  nav a:hover::after { transform: scaleX(1); }
  nav a.active { color: var(--accent); }
  nav a.active::after { transform: scaleX(1); }

  .nav-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn {
    padding: 8px 20px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text2);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: var(--glow);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  }
  .btn-primary:hover {
    background: #fff;
    box-shadow: var(--glow);
  }

  /* ——— HERO ——— */
  .hero {
    position: relative;
    padding: 80px 40px 60px;
    overflow: hidden;
    border-bottom: 1px solid var(--border2);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,200,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,200,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }

  .hero-glow {
    position: absolute;
    width: 600px;
    height: 400px;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(0,200,255,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .hero-tag::before {
    content: '// ';
    color: var(--text3);
  }

  h1 {
    font-family: 'Rajdhani', sans-serif;
    font-size: 64px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -1px;
    color: #fff;
    margin-bottom: 8px;
  }

  h1 span {
    color: var(--accent);
    display: block;
  }

  .hero-desc {
    font-size: 17px;
    font-weight: 300;
    color: var(--text2);
    line-height: 1.6;
    margin: 20px 0 32px;
    max-width: 460px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-large {
    padding: 14px 32px;
    font-size: 14px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .stat-card {
    background: var(--panel);
    border: 1px solid var(--border2);
    padding: 20px;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .stat-card.orange::before { background: linear-gradient(90deg, var(--accent2), transparent); }
  .stat-card.green::before { background: linear-gradient(90deg, var(--accent3), transparent); }
  .stat-card.gold::before { background: linear-gradient(90deg, var(--gold), transparent); }

  .stat-val {
    font-family: 'Rajdhani', sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text3);
    text-transform: uppercase;
    margin-top: 4px;
  }

  .stat-change {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--accent3);
    margin-top: 8px;
  }

  /* ——— MAIN LAYOUT ——— */
  .main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 24px;
  }

  /* ——— SIDEBAR ——— */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sidebar-section {
    background: var(--panel);
    border: 1px solid var(--border2);
  }

  .section-header {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border2);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text3);
    font-family: 'Share Tech Mono', monospace;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-header::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--accent);
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  }

  .sidebar-item {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
    border-bottom: 1px solid var(--border2);
    letter-spacing: 1px;
  }

  .sidebar-item:last-child { border-bottom: none; }
  .sidebar-item:hover { background: var(--panel2); color: #fff; }
  .sidebar-item.active { background: rgba(0,200,255,0.06); color: var(--accent); }

  .sidebar-item .icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    opacity: 0.7;
  }

  .badge {
    margin-left: auto;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    background: rgba(0,200,255,0.1);
    border: 1px solid rgba(0,200,255,0.2);
    color: var(--accent);
  }

  .badge.red {
    background: rgba(255,59,92,0.1);
    border-color: rgba(255,59,92,0.2);
    color: var(--red);
  }

  /* ——— CONTENT ——— */
  .content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ——— TOP BAR ——— */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 0 16px;
    height: 40px;
    flex: 1;
    max-width: 400px;
  }

  .search-bar input {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    letter-spacing: 1px;
    width: 100%;
  }

  .search-bar input::placeholder { color: var(--text3); }
  .search-icon { color: var(--text3); font-size: 14px; }

  .filter-row {
    display: flex;
    gap: 8px;
  }

  .filter-chip {
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text3);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Barlow Condensed', sans-serif;
  }

  .filter-chip:hover { border-color: var(--accent); color: var(--accent); }
  .filter-chip.active { background: rgba(0,200,255,0.1); border-color: var(--accent); color: var(--accent); }

  /* ——— PANELS ——— */
  .panel {
    background: var(--panel);
    border: 1px solid var(--border2);
  }

  .panel-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .panel-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .panel-title .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .panel-action {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    cursor: pointer;
    letter-spacing: 1px;
  }

  /* ——— GRID LAYOUTS ——— */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }

  /* ——— MATCH FEED ——— */
  .match-list { display: flex; flex-direction: column; }

  .match-row {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border2);
    display: grid;
    grid-template-columns: auto 1fr auto auto auto;
    align-items: center;
    gap: 20px;
    cursor: pointer;
    transition: background 0.15s;
  }

  .match-row:last-child { border-bottom: none; }
  .match-row:hover { background: var(--panel2); }

  .match-type {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    padding: 3px 8px;
    text-transform: uppercase;
    border: 1px solid;
  }

  .type-scrim { color: var(--accent); border-color: rgba(0,200,255,0.3); background: rgba(0,200,255,0.05); }
  .type-pub { color: var(--gold); border-color: rgba(255,209,102,0.3); background: rgba(255,209,102,0.05); }
  .type-stream { color: var(--accent2); border-color: rgba(255,107,53,0.3); background: rgba(255,107,53,0.05); }
  .type-pro { color: var(--accent3); border-color: rgba(127,255,90,0.3); background: rgba(127,255,90,0.05); }

  .match-teams {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .team-name {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    color: #fff;
  }

  .match-meta {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text3);
  }

  .match-result {
    font-family: 'Rajdhani', sans-serif;
    font-size: 20px;
    font-weight: 700;
    text-align: center;
    min-width: 60px;
  }

  .result-win { color: var(--accent3); }
  .result-loss { color: var(--red); }

  .match-duration {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--text2);
    text-align: right;
  }

  .match-kda {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text3);
  }

  .insights-tag {
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--accent2);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ——— HERO POOL ——— */
  .hero-grid-pool {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 6px;
    padding: 16px;
  }

  .hero-tile {
    aspect-ratio: 1;
    background: var(--panel2);
    border: 1px solid var(--border2);
    position: relative;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.15s;
  }

  .hero-tile:hover {
    border-color: var(--accent);
    transform: scale(1.05);
    z-index: 2;
  }

  .hero-tile .hero-abbr {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Rajdhani', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.6);
    text-align: center;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .hero-tile .wr-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .hero-tile.tier-s { border-color: var(--gold); }
  .hero-tile.tier-a { border-color: var(--accent); }
  .hero-tile.tier-b { border-color: var(--accent3); }
  .hero-tile.tier-c { border-color: var(--text3); }

  .hero-bg-fill {
    position: absolute;
    inset: 0;
    opacity: 0.15;
  }

  /* ——— STRATEGY BOARD ——— */
  .strategy-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 16px;
  }

  .strat-card {
    background: var(--bg3);
    border: 1px solid var(--border2);
    padding: 16px;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
    overflow: hidden;
  }

  .strat-card:hover { border-color: var(--accent); }

  .strat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent);
  }

  .strat-card.orange::before { background: var(--accent2); }
  .strat-card.green::before { background: var(--accent3); }
  .strat-card.gold::before { background: var(--gold); }

  .strat-name {
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #fff;
    margin-bottom: 6px;
  }

  .strat-desc {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .strat-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .strat-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    letter-spacing: 1px;
    background: rgba(0,200,255,0.08);
    border: 1px solid rgba(0,200,255,0.15);
    color: var(--accent);
  }

  .strat-wr {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: 'Rajdhani', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--accent3);
  }

  /* ——— ANALYTICS CHARTS ——— */
  .chart-area {
    padding: 16px 20px;
  }

  .bar-chart {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bar-row {
    display: grid;
    grid-template-columns: 100px 1fr 48px;
    align-items: center;
    gap: 12px;
  }

  .bar-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text2);
    letter-spacing: 1px;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-track {
    height: 20px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    position: relative;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    position: relative;
    transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bar-fill::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 2px;
    height: 100%;
    background: rgba(255,255,255,0.5);
  }

  .bar-val {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--text2);
  }

  /* ——— PLAYER TABLE ——— */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  thead th {
    padding: 10px 16px;
    text-align: left;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text3);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border2);
    white-space: nowrap;
  }

  tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(26,58,82,0.4);
    color: var(--text2);
    font-size: 14px;
    letter-spacing: 0.5px;
  }

  tbody tr:hover td { background: var(--panel2); }
  tbody tr:last-child td { border-bottom: none; }

  .player-name {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-weight: 600;
  }

  .avatar {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--accent), #0044aa);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .rank-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    padding: 2px 8px;
    background: rgba(255,209,102,0.08);
    border: 1px solid rgba(255,209,102,0.2);
    color: var(--gold);
    white-space: nowrap;
  }

  .perf-bar {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mini-bar {
    flex: 1;
    height: 4px;
    background: var(--bg3);
    position: relative;
    max-width: 80px;
  }

  .mini-bar-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    background: var(--accent);
  }

  /* ——— LIVE FEED ——— */
  .live-feed {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-height: 280px;
    overflow-y: auto;
  }

  .live-feed::-webkit-scrollbar { width: 4px; }
  .live-feed::-webkit-scrollbar-track { background: var(--bg2); }
  .live-feed::-webkit-scrollbar-thumb { background: var(--border); }

  .feed-item {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .feed-time {
    font-family: 'Share Tech Mono', monospace;
